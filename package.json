{
  "name": "openclaw-agent-protocol",
  "version": "1.0.1",
  "description": "Infrastructure-level routing enforcement for OpenClaw multi-agent systems. Agents must dispatch restricted tools to the correct specialist — enforced at the gateway level, not the prompt level.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "openclaw-agent-protocol": "dist/wizard.js"
  },
  "scripts": {
    "build": "tsc",
    "setup": "node dist/wizard.js",
    "prepublishOnly": "npm run build"
  },
  "openclaw": {
    "extensions": ["./dist/index.js"],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    },
    "build": {
      "openclawVersion": "2026.4.10",
      "pluginSdkVersion": "2026.4.10"
    }
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "glob": "^11.0.0",
    "minimatch": "^9.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "openclaw",
    "agent-protocol",
    "multi-agent",
    "openclaw-plugin"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/pavelveselov-art/openclaw-agent-protocol"
  }
}
