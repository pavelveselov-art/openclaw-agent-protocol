{
  "enabled": true,
  "mode": "enforce",
  "description": "Default Hard Stop policy — routes tool calls to the correct specialist agent. Generated by agent-routing-enforcer wizard.",
  "routing": {
    "exec": "sentinel",
    "execute_code": "coder",
    "write_file": {
      "coder": ["**/*.py", "**/*.js", "**/*.ts", "**/*.sh", "**/src/**", "**/lib/**", "**/scripts/**"],
      "researcher": ["**/research/**", "**/reports/**"]
    },
    "patch": {
      "coder": ["**/*.py", "**/*.js", "**/*.ts", "**/*.sh", "**/src/**", "**/lib/**", "**/scripts/**"],
      "researcher": ["**/research/**", "**/reports/**"]
    },
    "browser_navigate": "ghost",
    "browser_click": "ghost",
    "browser_type": "ghost",
    "web_search": "ghost",
    "web_extract": "ghost"
  },
  "allowTools": [
    "read_file",
    "search_files",
    "session_search",
    "memory",
    "delegate_task",
    "cronjob",
    "clarify",
    "text_to_speech"
  ]
}
